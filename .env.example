# Application metadata
APP_NAME="AI Microservice"
APP_VERSION="0.1.0"
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Uvicorn bind options (used by Settings; overridden by Docker CMD host)
HOST=0.0.0.0
PORT=8000


# Embeddings backend
EMBEDDINGS_PROVIDER=fake
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# CORS allowed origins
# Accepts either JSON array or comma-separated string.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# OCR / extraction (used for regulation monitoring and case documents)
OCR_PRIMARY_PROVIDER=alapi
OCR_SECONDARY_PROVIDER=none
ALAPI_BASE_URL=https://alapi.deep.sa
ALAPI_API_KEY=
ALAPI_OCR_PATH=/ocr
SOURCE_WHITELIST_DOMAINS=laws.boe.gov.sa,laws.moj.gov.sa,boe.gov.sa,moj.gov.sa
EXTRACTION_TIMEOUT_SECONDS=30
EXTRACTION_MAX_BYTES=15000000
EXTRACTION_MAX_CHARS=120000
OCR_MIN_TEXT_CHARS=400
OCR_STRICT_MODE=false

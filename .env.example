# Fine-tuning / extract_citations pipeline (same DB as Node backend)
# DATABASE_URL=postgresql://user:password@localhost:5432/silah_legal

# Application metadata
APP_NAME="AI Microservice"
APP_VERSION="0.1.0"
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Uvicorn bind options (used by Settings; overridden by Docker CMD host)
HOST=0.0.0.0
PORT=8000


# Embeddings backend
# Use bge for real 1024-d embeddings in local RAG flows.
EMBEDDINGS_PROVIDER=bge
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# CORS allowed origins
# Accepts either JSON array or comma-separated string.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# OCR / extraction (used for regulation monitoring and case documents)
OCR_PRIMARY_PROVIDER=alapi
OCR_SECONDARY_PROVIDER=none
ALAPI_BASE_URL=https://alapi.deep.sa
ALAPI_API_KEY=
ALAPI_OCR_PATH=/ocr
SOURCE_WHITELIST_DOMAINS=laws.boe.gov.sa,laws.moj.gov.sa,boe.gov.sa,moj.gov.sa
EXTRACTION_TIMEOUT_SECONDS=30
EXTRACTION_MAX_BYTES=15000000
EXTRACTION_MAX_CHARS=120000
OCR_MIN_TEXT_CHARS=400
OCR_STRICT_MODE=false

# Document case insights
INSIGHTS_DEFAULT_TOP_K=5
INSIGHTS_MAX_SOURCE_CHARS=15000
INSIGHTS_SUMMARY_SENTENCES=4

# Gemini (LLM verification, HyDE, agentic stages in /similarity/find-related)
# Set in .env (not committed). Key is read only by this service, not the Node backend.
GEMINI_API_KEY=
GEMINI_ENABLED=false
# Examples: gemini-3-flash-preview | gemini-3.1-flash-lite-preview | gemini-2.0-flash
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=60
GEMINI_TOP_N_CANDIDATES=15

# Optional pipeline flags (see ai_service/app/config.py)
# HYDE_ENABLED=false
# AGENTIC_RETRIEVAL_ENABLED=false
# CROSS_ENCODER_ENABLED=false
# COLBERT_ENABLED=false
